FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY node-agri-map-server/package*.json ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy application code
COPY node-agri-map-server/ .

# Create logs directory
RUN mkdir -p logs

# Expose port
EXPOSE 3000

# Start the application
CMD ["npm", "start"]
