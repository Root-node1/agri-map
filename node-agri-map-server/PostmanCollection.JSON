{
  "info": {
    "name": "AgriMap Finance API (Node.js)",
    "_postman_id": "b9c1e8f2-agrimap-node-collection",
    "description": "Postman collection for AgriMap Node.js backend (Finance, Loans, Carbon Credits, Wallet, Payments)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Loans",
      "item": [
        {
          "name": "Apply for Loan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cooperative_id\": \"coop_123\",\n  \"amount\": 5000,\n  \"purpose\": \"Irrigation upgrade\"\n}"
            },
            "url": "{{base_url}}/loans/apply"
          }
        },
        {
          "name": "Get Loan Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/loans/{{loan_id}}"
          }
        }
      ]
    },
    {
      "name": "Carbon Credits",
      "item": [
        {
          "name": "List Carbon Credits",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/carbon-credits"
          }
        },
        {
          "name": "Tokenize Carbon Credits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"field_id\": \"field_123\",\n  \"carbon_tons\": 2.3\n}"
            },
            "url": "{{base_url}}/carbon-credits/tokenize"
          }
        },
        {
          "name": "Sell Carbon Credits",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credits\": 5\n}"
            },
            "url": "{{base_url}}/carbon-credits/sell"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Disburse Loan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loan_id\": \"loan_123\",\n  \"amount\": 5000\n}"
            },
            "url": "{{base_url}}/payments/disburse"
          }
        },
        {
          "name": "Repay Loan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"loan_id\": \"loan_123\",\n  \"amount\": 500\n}"
            },
            "url": "{{base_url}}/payments/repay"
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet Balance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/wallet"
          }
        },
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/wallet/transactions"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    }
  ]
}