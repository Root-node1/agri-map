SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True

# Database — PostgreSQL on Render
DATABASE_URL=postgres://user:password@host:5432/ecotrack

# Hosts
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://localhost:3000

# Copernicus Data Space Ecosystem / Sentinel Hub credentials
# Sign up (free): https://dataspace.copernicus.eu
# Then create OAuth client at: https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_BASE_URL=https://sh.dataspace.copernicus.eu
SENTINEL_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
